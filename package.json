{
  "name": "order-system",
  "version": "0.1.0",
  "private": true,
  "main": "electron-dist/main.js",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "build:electron-ts": "tsc -p electron/tsconfig.json",
    "electron": "electron .",
    "electron-dev": "concurrently \"npm run dev\" \"tsc -p electron/tsconfig.json -w\" \"electron .\"",
    "build-electron": "npm run build && npm run build:electron-ts && electron-builder",
    "tailwind:build": "tailwindcss build -o styles.css"
  },
  "dependencies": {
    "axios": "^1.7.9",
    "chart.js": "^4.4.7",
    "file-saver": "^2.0.5",
    "file-saver-es": "^2.0.5",
    "firebase": "^10.14.1",
    "firebase-admin": "^13.6.0",
    "next": "^16.0.7",
    "nodemailer": "^7.0.5",
    "qrcode": "^1.5.4",
    "react": "^19.0.0",
    "react-chartjs-2": "^5.3.0",
    "react-datepicker": "^7.6.0",
    "react-dom": "^19.0.0",
    "react-icons": "^5.4.0",
    "react-time-picker": "^7.0.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@types/file-saver": "^2.0.7",
    "@types/node": "^20",
    "@types/nodemailer": "^7.0.0",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@typescript-eslint/eslint-plugin": "^8.20.0",
    "@typescript-eslint/parser": "^8.20.0",
    "concurrently": "^8.2.2",
    "electron": "^34.0.0",
    "electron-builder": "^24.13.3",
    "eslint": "^9.18.0",
    "eslint-config-next": "15.1.5",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "typescript": "^5"
  },
  "build": {
    "appId": "com.order-system.app",
    "productName": "Sweet Order System",
    "directories": {
      "output": "dist"
    },
    "files": [
      ".next/**/*",
      "electron-dist/**/*",
      "electron/**/*",
      "node_modules/**/*",
      "public/**/*",
      "src/**/*",
      "package.json"
    ],
    "extraMetadata": {
      "main": "electron-dist/main.js"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "win": {
      "target": "portable",
      "icon": "public/favicon.ico"
    }
  }
}
